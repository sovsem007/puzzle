<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#0D0D1A">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="API ключ Claude"
        android:textColor="#D4AF37"
        android:textSize="16sp"
        android:textStyle="bold"
        android:paddingBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Для работы приложения необходим API ключ Anthropic Claude.\nПолучить: console.anthropic.com"
        android:textColor="#8888AA"
        android:textSize="13sp"
        android:paddingBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1A1A2E"
        android:padding="8dp"
        android:layout_marginBottom="16dp">

        <EditText
            android:id="@+id/et_api_key"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="sk-ant-..."
            android:textColor="#E8E8F0"
            android:textColorHint="#8888AA"
            android:background="@android:color/transparent"
            android:padding="8dp"
            android:inputType="textPassword"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btn_toggle_visibility"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Показать"
            android:textSize="12sp"
            android:textColor="#D4AF37"
            android:background="@android:color/transparent" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_save"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Сохранить"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#0D0D1A"
        android:background="#D4AF37" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ключ сохраняется только на вашем устройстве."
        android:textColor="#8888AA"
        android:textSize="12sp"
        android:paddingTop="24dp"
        android:gravity="center" />

</LinearLayout>
