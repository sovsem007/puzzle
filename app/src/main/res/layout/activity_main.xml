<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D1A">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Хиромант"
        android:textColor="#D4AF37"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Анализ ладони с помощью ИИ"
        android:textColor="#D4AF37"
        android:textSize="13sp"
        android:textStyle="italic"
        android:gravity="center"
        android:paddingBottom="8dp" />

    <ImageView
        android:id="@+id/iv_palm_preview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scaleType="centerCrop"
        android:background="#1A1A2E"
        android:contentDescription="Palm preview" />

    <TextView
        android:id="@+id/tv_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Нажмите для выбора фото ладони"
        android:textColor="#8888AA"
        android:textSize="12sp"
        android:gravity="center"
        android:padding="8dp" />

    <TextView
        android:id="@+id/tv_api_key_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#FFCC44"
        android:textSize="12sp"
        android:gravity="center"
        android:paddingBottom="4dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp">

        <Button
            android:id="@+id/btn_camera"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="Камера"
            android:textColor="#D4AF37"
            android:background="#1A1A2E" />

        <Button
            android:id="@+id/btn_gallery"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="Галерея"
            android:textColor="#D4AF37"
            android:background="#1A1A2E" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_analyze"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginHorizontal="8dp"
        android:text="Анализировать ладонь"
        android:textColor="#0D0D1A"
        android:textStyle="bold"
        android:background="#D4AF37"
        android:enabled="false" />

    <Button
        android:id="@+id/btn_settings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Настройки API"
        android:textColor="#8888AA"
        android:background="@android:color/transparent" />

</LinearLayout>
