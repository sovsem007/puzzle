<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    tools:context=".MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_dark">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/app_name"
            app:titleTextColor="@color/gold"
            app:navigationIconTint="@color/gold" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Header -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/app_subtitle"
                android:textColor="@color/gold"
                android:textSize="14sp"
                android:textStyle="italic"
                android:gravity="center"
                android:paddingBottom="16dp" />

            <!-- Palm preview -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="300dp"
                app:cardBackgroundColor="@color/surface_dark"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:id="@+id/iv_palm_preview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_palm_placeholder" />

                    <TextView
                        android:id="@+id/tv_hint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|center_horizontal"
                        android:background="#80000000"
                        android:padding="8dp"
                        android:text="@string/select_photo_hint"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:layout_margin="8dp" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Buttons row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_camera"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="@string/camera"
                    app:icon="@drawable/ic_camera"
                    app:backgroundTint="@color/surface_dark"
                    android:textColor="@color/gold"
                    app:iconTint="@color/gold"
                    app:strokeColor="@color/gold"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_gallery"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="@string/gallery"
                    app:icon="@drawable/ic_gallery"
                    app:backgroundTint="@color/surface_dark"
                    android:textColor="@color/gold"
                    app:iconTint="@color/gold"
                    app:strokeColor="@color/gold"
                    app:strokeWidth="1dp" />
            </LinearLayout>

            <!-- API Key hint -->
            <TextView
                android:id="@+id/tv_api_key_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFCC44"
                android:textSize="12sp"
                android:gravity="center"
                android:paddingBottom="8dp" />

            <!-- Analyze button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_analyze"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/analyze"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@color/gold"
                android:textColor="@color/background_dark"
                android:layout_marginBottom="12dp"
                android:enabled="false" />

            <!-- Settings button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_settings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings"
                app:icon="@drawable/ic_settings"
                app:backgroundTint="@color/transparent"
                android:textColor="@color/text_secondary"
                app:iconTint="@color/text_secondary"
                app:strokeColor="@color/transparent" />

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
